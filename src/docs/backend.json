
{
  "entities": {
    "CompanyBranding": {
      "title": "Company Branding",
      "description": "Stores the company's branding information for letterheads and general UI.",
      "type": "object",
      "properties": {
        "company_name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "logo_url": { "type": "string", "format": "uri" },
        "system_background_url": { "type": "string", "format": "uri" }
      },
      "required": ["company_name"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's login account.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Secretary", "Accountant", "Engineer", "HR"] },
        "employeeId": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "ConstructionProject": {
      "title": "Construction Project",
      "description": "Represents an active construction site/project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "clientId": { "type": "string" },
        "status": { "type": "string", "enum": ["مخطط", "قيد التنفيذ", "مكتمل", "معلق", "ملغى"] },
        "contractValue": { "type": "number" },
        "progressPercentage": { "type": "number" },
        "boqId": { "type": "string" }
      }
    },
    "DailySiteReport": {
      "title": "Daily Site Report",
      "description": "Technical progress report submitted daily by the site engineer.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "engineerId": { "type": "string" },
        "engineerName": { "type": "string" },
        "workCompleted": { "type": "string" },
        "photoUrls": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "date", "workCompleted"]
    },
    "PaymentApplication": {
      "title": "Payment Application (Mustakhlas)",
      "description": "A formal billing document submitted to the client based on BOQ progress.",
      "type": "object",
      "properties": {
        "applicationNumber": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "projectId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "projectName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "boqItemId": { "type": "string" },
              "description": { "type": "string" },
              "unit": { "type": "string" },
              "unitPrice": { "type": "number" },
              "previousQuantity": { "type": "number" },
              "currentQuantity": { "type": "number" },
              "totalQuantity": { "type": "number" },
              "totalAmount": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "submitted", "approved", "paid", "cancelled"] },
        "journalEntryId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["applicationNumber", "projectId", "clientId", "items", "totalAmount"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/company_settings/{settingsId}": {
      "schema": { "$ref": "#/entities/CompanyBranding" },
      "description": "Stores company-wide settings."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/ConstructionProject" },
      "description": "Main projects collection."
    },
    "/projects/{projectId}/daily_reports/{reportId}": {
      "schema": { "$ref": "#/entities/DailySiteReport" },
      "description": "Daily technical reports for a specific project."
    },
    "/payment_applications/{appId}": {
      "schema": { "$ref": "#/entities/PaymentApplication" },
      "description": "Client billing documents (Mustakhlasat)."
    }
  }
}
