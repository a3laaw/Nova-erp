
{
  "entities": {
    "SubsidyQuota": {
      "title": "Subsidy Quota",
      "description": "Tracks material quotas provided by the government for private housing projects.",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "itemName": { "type": "string" },
        "allocatedQuantity": { "type": "number" },
        "receivedQuantity": { "type": "number" },
        "consumedQuantity": { "type": "number" },
        "unitPrice": { "type": "number", "description": "Market price for evaluation" }
      }
    },
    "ConstructionProject": {
      "title": "Construction Project",
      "description": "Main project entity, now with subsidy support.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "projectCategory": { "type": "string", "enum": ["Private (Subsidized)", "Private (Non-Subsidized)", "Commercial", "Government"] },
        "subsidyQuotas": { "type": "array", "items": { "$ref": "#/entities/SubsidyQuota" } }
      }
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/ConstructionProject" },
      "description": "Stores all construction projects and their subsidy data."
    }
  }
}
