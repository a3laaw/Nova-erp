
{
  "entities": {
    "CompanyBranding": {
      "title": "Company Branding",
      "description": "Stores the company's branding information for letterheads and general UI.",
      "type": "object",
      "properties": {
        "company_name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "logo_url": { "type": "string", "format": "uri" },
        "system_background_url": { "type": "string", "format": "uri" }
      },
      "required": ["company_name"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's login account.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Secretary", "Accountant", "Engineer", "HR"] },
        "employeeId": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "ConstructionProject": {
      "title": "Construction Project",
      "description": "Represents an active construction site/project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "clientId": { "type": "string" },
        "status": { "type": "string", "enum": ["مخطط", "قيد التنفيذ", "مكتمل", "معلق", "ملغى"] },
        "contractValue": { "type": "number" },
        "progressPercentage": { "type": "number" },
        "boqId": { "type": "string" }
      }
    },
    "BoqItem": {
      "title": "Bill of Quantities Item",
      "description": "A single line item in a BOQ with scheduling data.",
      "type": "object",
      "properties": {
        "itemNumber": { "type": "string" },
        "description": { "type": "string" },
        "unit": { "type": "string" },
        "quantity": { "type": "number" },
        "sellingUnitPrice": { "type": "number" },
        "isHeader": { "type": "boolean" },
        "parentId": { "type": "string" },
        "level": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" }
      }
    },
    "DailySiteReport": {
      "title": "Daily Site Report",
      "description": "Technical progress report submitted daily by the site engineer.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "engineerId": { "type": "string" },
        "engineerName": { "type": "string" },
        "workCompleted": { "type": "string" },
        "photoUrls": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "date", "workCompleted"]
    },
    "InventoryAdjustment": {
        "title": "Inventory Adjustment / Return",
        "description": "Records stock changes including sales and purchase returns.",
        "type": "object",
        "properties": {
            "adjustmentNumber": { "type": "string" },
            "date": { "type": "string", "format": "date-time" },
            "type": { "type": "string", "enum": ["opening_balance", "damage", "theft", "material_issue", "purchase_return", "sales_return", "transfer", "other"] },
            "clientId": { "type": "string" },
            "vendorId": { "type": "string" },
            "projectId": { "type": "string" },
            "warehouseId": { "type": "string" },
            "journalEntryId": { "type": "string" }
        }
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/company_settings/{settingsId}": {
      "schema": { "$ref": "#/entities/CompanyBranding" },
      "description": "Stores company-wide settings."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/ConstructionProject" },
      "description": "Main projects collection."
    },
    "/boqs/{boqId}/items/{itemId}": {
      "schema": { "$ref": "#/entities/BoqItem" },
      "description": "BOQ items with scheduling."
    },
    "/inventoryAdjustments/{adjustmentId}": {
      "schema": { "$ref": "#/entities/InventoryAdjustment" },
      "description": "Stock adjustments and returns."
    }
  }
}
