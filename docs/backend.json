
{
  "entities": {
    "CompanyBranding": {
      "title": "Company Branding",
      "description": "Stores the company's branding information for letterheads and general UI.",
      "type": "object",
      "properties": {
        "company_name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "logo_url": { "type": "string", "format": "uri" },
        "system_background_url": { "type": "string", "format": "uri" }
      },
      "required": ["company_name"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's login account.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Secretary", "Accountant", "Engineer", "HR"] },
        "employeeId": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "FieldVisit": {
      "title": "Field Visit",
      "description": "A scheduled or confirmed site visit by an engineer.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "transactionId": { "type": "string" },
        "transactionType": { "type": "string" },
        "engineerId": { "type": "string" },
        "engineerName": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "plannedStageId": { "type": "string" },
        "plannedStageName": { "type": "string" },
        "status": { "type": "string", "enum": ["planned", "confirmed", "cancelled"] },
        "confirmationData": {
          "type": "object",
          "properties": {
            "confirmedAt": { "type": "string", "format": "date-time" },
            "notes": { "type": "string" },
            "location": {
              "type": "object",
              "properties": {
                "latitude": { "type": "number" },
                "longitude": { "type": "number" },
                "accuracy": { "type": "number" }
              }
            },
            "isCompleted": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "transactionId", "scheduledDate", "engineerId", "status"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/company_settings/{settingsId}": {
      "schema": { "$ref": "#/entities/CompanyBranding" },
      "description": "Stores company-wide settings."
    },
    "/field_visits/{visitId}": {
      "schema": { "$ref": "#/entities/FieldVisit" },
      "description": "Scheduled and confirmed field visits."
    }
  }
}
