
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's login account within a tenant.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Engineer", "Accountant", "HR", "Secretary"] },
        "isActive": { "type": "boolean" }
      }
    },
    "UserProductivityItem": {
      "title": "User Productivity Item",
      "description": "Represents a Task or a Bookmark created by a user from an ERP entity.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "entryType": { "type": "string", "enum": ["task", "bookmark"] },
        "title": { "type": "string" },
        "actionType": { "type": "string", "enum": ["review", "decision", "design", "redesign", "meeting", "general"] },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed", "cancelled"] },
        "startDate": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" },
        "sourceModule": { "type": "string" },
        "sourceId": { "type": "string" },
        "sourceSubId": { "type": "string" }
      },
      "required": ["userId", "entryType", "title", "sourceModule", "sourceId"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/companies/{companyId}/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Tenant-specific user records."
    },
    "/companies/{companyId}/userProductivity/{itemId}": {
      "schema": { "$ref": "#/entities/UserProductivityItem" },
      "description": "Personal productivity items (Tasks/Bookmarks) for users."
    }
  }
}
