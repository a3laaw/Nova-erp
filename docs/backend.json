{
  "entities": {
    "CustodyReconciliation": {
      "title": "Custody Reconciliation",
      "description": "Represents an employee's report of expenses spent from their cash custody.",
      "type": "object",
      "properties": {
        "reconciliationNumber": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "amount": { "type": "number" },
              "category": { "type": "string" },
              "categoryName": { "type": "string" },
              "attachmentUrl": { "type": "string", "format": "uri" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["employeeId", "date", "items", "totalAmount"]
    }
  },
  "firestore": {
    "/custody_reconciliations/{id}": {
      "schema": { "$ref": "#/entities/CustodyReconciliation" },
      "description": "Stores employee custody reconciliation requests."
    }
  }
}