
{
  "entities": {
    "CompanyBranding": {
      "title": "Company Branding",
      "description": "Stores the company's branding information for letterheads and general UI.",
      "type": "object",
      "properties": {
        "company_name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "logo_url": { "type": "string", "format": "uri" },
        "system_background_url": { "type": "string", "format": "uri" },
        "external_config": { 
            "type": "object",
            "description": "Optional dynamic Firebase configuration for companies with their own hosting."
        }
      },
      "required": ["company_name"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's login account, now linked to a specific company.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Secretary", "Accountant", "Engineer", "HR"] },
        "employeeId": { "type": "string" },
        "companyId": { "type": "string", "description": "The unique ID of the company this user belongs to." },
        "isActive": { "type": "boolean" }
      },
      "required": ["username", "role", "companyId"]
    },
    "RecurringObligation": {
      "title": "Recurring Obligation",
      "description": "Automated weekly/monthly payments like rents, installments, and daily labor.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["rent", "installment", "vendor_debt", "daily_labor"] },
        "amount": { "type": "number" },
        "frequency": { "type": "string", "enum": ["weekly", "monthly"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "debitAccountId": { "type": "string" },
        "creditAccountId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "paused", "completed"] }
      },
      "required": ["title", "type", "amount", "frequency", "dueDate"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/company_settings/{settingsId}": {
      "schema": { "$ref": "#/entities/CompanyBranding" },
      "description": "Stores company-wide settings and optional external hosting configurations."
    },
    "/recurring_obligations/{obligationId}": {
      "schema": { "$ref": "#/entities/RecurringObligation" },
      "description": "Stores automated financial recurring tasks."
    }
  }
}
