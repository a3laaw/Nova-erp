rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'Admin';
    }

    function isSecretary() {
      return isAuthenticated() && getUserRole() == 'Secretary';
    }

    function isHR() {
      return isAuthenticated() && getUserRole() == 'HR';
    }
    
    function isEngineer() {
      return isAuthenticated() && getUserRole() == 'Engineer';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Path Rules
    match /users/{userId} {
      // Allow unauthenticated query for login check.
      // NOTE: In production, this should be handled by a server-side function.
      allow list: if true; 
      // Admins can get any user. Any authenticated user can read their OWN profile.
      allow get: if isAdmin() || isOwner(userId);
      allow write: if isAdmin();
      // Allow user creation for login flow
      allow create: if true; 
    }
    
    match /clients/{clientId} {
      // Admins and Secretaries can manage clients.
      allow read, write: if isAdmin() || isSecretary();
    }

    match /employees/{employeeId} {
      // Admins, HR, and Secretaries can read and create employees.
      allow read, create: if isAdmin() || isHR() || isSecretary();
      // Only Admins and HR can update or delete employees.
      allow update, delete: if isAdmin() || isHR();
    }
    
    // Default deny all other reads/writes
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
