rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Checks if the requesting user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Path Rules
    match /users/{userId} {
      // Allow any authenticated user to get their own profile.
      allow get: if isOwner(userId);

      // Anyone can create a user (for sign-up).
      allow create: if true;
      
      // Only the user themselves can update their profile.
      allow update: if isOwner(userId);
      
      // Temporarily allow list for username lookup during the local auth flow.
      // In a production app with secure Cloud Functions, this would be `if false`.
      allow list: if true;
    }
    
    match /clients/{clientId} {
      // For now, allow any authenticated user to manage clients.
      allow read, write: if isAuthenticated();
    }

    match /employees/{employeeId} {
       // For now, allow any authenticated user to manage employees.
      allow read, write: if isAuthenticated();
    }
    
    // Default deny all other reads/writes for security.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
