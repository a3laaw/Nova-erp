rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isAuthOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    function isSecretary() {
        return getUserRole() == 'secretary';
    }

    function isHR() {
        return getUserRole() == 'hr';
    }

    match /users/{userId} {
      // Admins can read and write any user profile
      // Users can only read their own profile
      allow read: if isAdmin() || isAuthOwner(userId);
      allow write: if isAdmin();
    }
    
    match /clients/{clientId} {
      allow read, write: if isAdmin() || isSecretary();
    }

    match /employees/{employeeId} {
      allow read, write: if isAdmin() || isHR();
    }
  }
}
