rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 🛡️ بروتوكول المعماري السيادي (V50.0) ---
    // المطور الأصلي هو المتحكم الوحيد في البنية التحتية
    function isSovereignArchitect() {
      return request.auth != null && 
             (request.auth.token.email.lower() == 'alaawaaheeb@gmail.com' || 
              request.auth.token.role == 'Developer');
    }

    // المستخدم ينتمي للمنشأة إذا كان الـ ID متطابق في التوكن أو البيانات
    function belongsToCompany(companyId) {
      return request.auth != null && 
             (request.auth.token.companyId == companyId || 
              request.auth.token.currentCompanyId == companyId ||
              resource.data.companyId == companyId);
    }

    // السماح للمطور بالدخول المطلق لتأسيس المنظومة
    match /developers/{uid} {
      allow read, write: if isSovereignArchitect();
    }

    // المنشآت: المطور يرى الكل، والمستخدم يرى منشأته فقط
    match /companies/{companyId} {
      allow read, write: if isSovereignArchitect() || belongsToCompany(companyId);
      
      match /{allSubcollections=**} {
        allow read, write: if isSovereignArchitect() || belongsToCompany(companyId);
      }
    }

    // الفهرس العالمي للمستخدمين
    match /global_users/{docId} {
      // السماح للمستخدم بقراءة سجله الخاص لمعرفة منشأته عند الدخول
      allow read: if request.auth != null && (request.auth.uid == docId || isSovereignArchitect());
      allow write: if isSovereignArchitect();
    }
    
    // طلبات الانضمام: مفتوحة للجميع للإرسال، للمطور للمراجعة
    match /company_requests/{requestId} {
      allow create: if true;
      allow read, write: if isSovereignArchitect();
    }

    // القاعدة الذهبية: المعماري السيادي يملك الحق في كل شيء
    match /{document=**} {
      allow read, write: if isSovereignArchitect();
    }
  }
}