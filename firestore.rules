
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ مصفوفة الصلاحيات الموحدة (V132.0 - Sovereign Master Edition)
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // ⚡ محرك التعرف على المطور السيادي (Sovereign ID Engine)
    function isDeveloper() {
      return isAuthenticated() && 
             (request.auth.token.role == 'Developer' || 
              request.auth.token.isSuperAdmin == true ||
              request.auth.token.email.lower() == 'alaawaaheeb@gmail.com');
    }

    // 🛡️ محرك التحقق من العضوية والسيادة على المنشأة
    function isTenantMember(companyId) {
      return isAuthenticated() && 
             (request.auth.token.companyId == companyId || 
              request.auth.token.currentCompanyId == companyId);
    }

    // 🛡️ رادار الخصوصية للأدوار (Visibility Shield Logic)
    function isPrivilegedRole() {
        return request.auth.token.role in ['Admin', 'Accountant', 'HR', 'Secretary', 'Developer'];
    }

    // 🏯 قاعدة الوصول الشاملة للمطور المعتمد (Master Key)
    match /{document=**} {
      allow read, write: if isDeveloper();
    }

    // 🏢 عزل بيانات المنشآت (SaaS Multi-tenancy Protection)
    match /companies/{companyId} {
      allow read: if isDeveloper() || isTenantMember(companyId);
      allow write: if isDeveloper() || isTenantMember(companyId);
      
      // 🛡️ حماية المعاملات (Transactions Visibility) 🛡️
      match /transactions/{txId} {
        allow read: if isDeveloper() || (isTenantMember(companyId) && (isPrivilegedRole() || resource.data.assignedEngineerId == request.auth.token.employeeId));
        allow write: if isDeveloper() || (isTenantMember(companyId) && isPrivilegedRole());
      }

      // حماية المعاملات داخل ملف العميل (Nested Paths)
      match /clients/{clientId}/transactions/{txId} {
        allow read: if isDeveloper() || (isTenantMember(companyId) && (isPrivilegedRole() || resource.data.assignedEngineerId == request.auth.token.employeeId));
        allow write: if isDeveloper() || (isTenantMember(companyId) && isPrivilegedRole());
      }
      
      // السماح بالوصول لكافة المجموعات الفرعية الأخرى
      match /{allSubcollections=**} {
        allow read, write: if isDeveloper() || isTenantMember(companyId);
      }
    }

    // 🌍 الفهرس العالمي للمستخدمين
    match /global_users/{uid} {
      allow read: if true; 
      allow write: if isDeveloper() || (isAuthenticated() && request.auth.uid == uid);
    }
  }
}
