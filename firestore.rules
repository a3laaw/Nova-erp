rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ مصفوفة الصلاحيات الموحدة (V126.0)
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDeveloper() {
      return isAuthenticated() && 
             (request.auth.token.role == 'Developer' || request.auth.token.isSuperAdmin == true);
    }

    function isTenantMember(companyId) {
      return isAuthenticated() && 
             (request.auth.token.companyId == companyId || 
              request.auth.token.currentCompanyId == companyId);
    }

    // 🏯 قاعدة الوصول الشاملة للمطور المعتمد
    match /{document=**} {
      allow read, write: if isDeveloper();
    }

    // 🏢 عزل بيانات المنشآت (Multi-tenancy Isolation)
    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow write: if isDeveloper() || isTenantMember(companyId);
      
      match /{allSubcollections=**} {
        allow read, write: if isDeveloper() || isTenantMember(companyId);
      }
    }

    // 🌍 الفهرس العالمي للمستخدمين
    match /global_users/{uid} {
      allow read: if true; 
      allow write: if isDeveloper() || (isAuthenticated() && request.auth.uid == uid);
    }
    
    match /company_requests/{id} {
      allow create: if isAuthenticated(); 
      allow read, write: if isDeveloper();
    }

    // 📊 تحصين الاستعلامات المجمعة (Collection Group Security)
    // يجب أن تتطابق هذه القواعد مع الفلاتر المستخدمة في الكود البرمجي
    
    match /{path=**}/userProductivity/{id} {
        allow read: if isAuthenticated() && (isDeveloper() || resource.data.companyId == request.auth.token.companyId);
        allow write: if isAuthenticated() && (isDeveloper() || request.resource.data.companyId == request.auth.token.companyId);
    }

    match /{path=**}/transactions/{id} {
        allow read: if isAuthenticated() && (isDeveloper() || resource.data.companyId == request.auth.token.companyId);
    }

    match /{path=**}/timelineEvents/{id} {
        allow read: if isAuthenticated() && (isDeveloper() || resource.data.companyId == request.auth.token.companyId);
        allow write: if isAuthenticated() && (isDeveloper() || request.resource.data.companyId == request.auth.token.companyId);
    }

    match /{path=**}/leaveRequests/{id} {
        allow read: if isAuthenticated() && (isDeveloper() || resource.data.companyId == request.auth.token.companyId);
    }

    match /{path=**}/permissionRequests/{id} {
        allow read: if isAuthenticated() && (isDeveloper() || resource.data.companyId == request.auth.token.companyId);
    }
  }
}