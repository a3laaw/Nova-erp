rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- مساعدات الحوكمة ---
    function isDeveloper() {
      return request.auth != null && 
             request.auth.token.role == 'Developer';
    }

    function belongsToCompany(companyId) {
      return request.auth != null && 
             (request.auth.token.companyId == companyId || request.auth.token.currentCompanyId == companyId);
    }

    // --- 1. طلبات الانضمام (عام للكل للإرسال) ---
    // هذا الممر يسمح للزوار بوضع طلباتهم ليراها المطور في غرفة التحكم
    match /company_requests/{requestId} {
      allow create: if true; 
      allow read, write: if isDeveloper();
    }

    // --- 2. فهرس المستخدمين العالمي ---
    match /global_users/{docId} {
      allow read: if true; 
      allow write: if isDeveloper(); 
    }

    // --- 3. بيانات المطورين ---
    match /developers/{uid} {
      allow read, write: if isDeveloper();
    }

    // --- 4. بيانات الشركات المعزولة (The Isolated Tenants) ---
    match /companies/{companyId} {
      allow read: if isDeveloper() || belongsToCompany(companyId);
      allow write: if isDeveloper() || (belongsToCompany(companyId) && request.auth.token.role == 'Admin');
      
      match /{allSubcollections=**} {
        allow read, write: if isDeveloper() || belongsToCompany(companyId);
      }
    }

    // --- 5. العدادات ---
    match /counters/{doc} {
      allow read, write: if request.auth != null;
    }

    // --- 6. الحماية الافتراضية ---
    match /{document=**} {
      allow read, write: if isDeveloper();
    }
  }
}