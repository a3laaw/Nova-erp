rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSovereignArchitect() {
      return request.auth != null && 
             (request.auth.token.email.lower() == 'alaawaaheeb@gmail.com' || 
              request.auth.token.role == 'Developer');
    }

    function belongsToCompany(companyId) {
      return request.auth != null && 
             (request.auth.token.companyId == companyId || 
              request.auth.token.currentCompanyId == companyId ||
              get(/databases/$(database)/documents/companies/$(companyId)).data.adminEmail.lower() == request.auth.token.email.lower());
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /global_users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    match /companies/{companyId} {
      // 🛡️ السماح الصريح بالكتابة إذا كان المستخدم هو المدير (بناءً على البريد أو التوكن)
      allow read, write: if isSovereignArchitect() || belongsToCompany(companyId);
      
      match /{allSubcollections=**} {
        allow read, write: if isSovereignArchitect() || belongsToCompany(companyId);
      }
    }

    match /{document=**} {
      allow read, write: if isSovereignArchitect();
    }
  }
}