rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- مساعدات النظام السيادي ---
    function isDeveloper() {
      return request.auth != null && 
             request.auth.token.role == 'Developer' && 
             request.auth.token.isSuperAdmin == true;
    }

    function isCompanyAdmin(companyId) {
      return request.auth != null && 
             (request.auth.token.role == 'Admin' || request.auth.token.role == 'Developer') &&
             (request.auth.token.currentCompanyId == companyId || request.auth.token.companyId == companyId);
    }

    // السماح للمطور بالتحكم المطلق في مشروع الماستر
    match /developers/{uid} {
      allow read, write: if isDeveloper();
    }

    match /companies/{companyId} {
      // المطور يكتب في بيانات الربط، والادمن يقرأ فقط
      allow read: if request.auth != null;
      allow write: if isDeveloper();
      
      // السماح لمدير الشركة بتعديل الإعدادات والعلامة التجارية داخل مجلد شركته
      match /settings/{settingId} {
        allow read, write: if isCompanyAdmin(companyId);
      }
      
      // السماح لمدير الموظفين بالتحكم في المجلدات الفرعية
      match /{allSubcollections=**} {
        allow read, write: if isCompanyAdmin(companyId);
      }
    }

    // --- حماية سجلات الحركات والترقيم في الماستر ---
    match /counters/{doc} {
      allow read, write: if isDeveloper();
    }

    // --- القاعدة العامة للوصول المعزول ---
    match /{document=**} {
      allow read, write: if isDeveloper() || (request.auth != null && request.auth.uid != null);
    }
  }
}
