
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // --- Helper Functions ---
    // NOTE: These are temporarily bypassed by allowing all reads/writes.
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'Admin';
    }
    
    function isHR() {
      return isAuthenticated() && getUserdData().role == 'HR';
    }

    // --- Path Rules ---
    // WARNING: Rules are temporarily open for development with mock auth.
    // Re-secure before production.

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
