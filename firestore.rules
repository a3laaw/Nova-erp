
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Path Rules
    match /users/{userId} {
      // Allow read/write only to the owner of the document or an Admin.
      allow read, update: if isOwner(userId) || request.auth.token.role == 'Admin';
      
      // Allow Admins to list all users.
      allow list: if isAuthenticated() && request.auth.token.role == 'Admin';
      
      // Allow Admins to create or delete users.
      allow create, delete: if isAuthenticated() && request.auth.token.role == 'Admin';
    }
    
    match /clients/{clientId} {
      allow read, write: if isAuthenticated();
    }

    match /employees/{employeeId} {
      allow read, write: if isAuthenticated();
    }
    
    // Default deny all other reads/writes for security.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
