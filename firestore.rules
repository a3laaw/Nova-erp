rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Checks if the requesting user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Path Rules
    match /users/{userId} {
      // Temporarily allow unauthenticated list for login username lookup.
      // In production, this should be handled by a server-side Cloud Function.
      allow list: if true;

      // An authenticated user can get their OWN profile if we knew their UID.
      // But since we use anonymous auth, we can't enforce this rule effectively yet.
      // Allow any authenticated user to get for now.
      allow get: if isAuthenticated();

      // Only Admins or the user themselves can update a profile.
      // Since we can't verify roles securely yet without claims, we'll allow any authenticated user to update.
      allow update: if isAuthenticated();
      
      // Allow user creation for sign-up flows (if any).
      allow create: if true;
    }
    
    match /clients/{clientId} {
      // For now, allow any authenticated user to manage clients.
      allow read, write: if isAuthenticated();
    }

    match /employees/{employeeId} {
       // For now, allow any authenticated user to manage employees.
      allow read, write: if isAuthenticated();
    }
    
    // Default deny all other reads/writes for security.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
