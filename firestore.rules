rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ مصفوفة الصلاحيات السيادية (V125.0)
    
    function isDeveloper() {
      return request.auth != null && 
             (request.auth.token.isSuperAdmin == true || 
              request.auth.token.role == 'Developer');
    }

    function isTenantMember(companyId) {
      return request.auth != null && 
             (request.auth.token.companyId == companyId || 
              request.auth.token.currentCompanyId == companyId);
    }

    // 🏯 قاعدة الوصول الشاملة للمطور
    match /{document=**} {
      allow read, write: if isDeveloper();
    }

    // 🏢 عزل المنشآت
    match /companies/{companyId} {
      allow read: if request.auth != null;
      allow write: if isDeveloper() || isTenantMember(companyId);
      
      match /{allSubcollections=**} {
        allow read, write: if isDeveloper() || isTenantMember(companyId);
      }
    }

    // 🌍 الفهرس العالمي (Global Index)
    match /global_users/{uid} {
      // 🛡️ تصحيح سيادي: السماح بالقراءة العامة لتمكين البحث عن اليوزر عند الدخول قبل التسجيل
      allow read: if true; 
      allow write: if isDeveloper() || (request.auth != null && request.auth.uid == uid);
    }
    
    match /company_requests/{id} {
      allow create: if request.auth != null; 
      allow read, write: if isDeveloper();
    }

    // 📊 تحصين استعلامات المجموعات
    match /{path=**}/userProductivity/{id} {
        allow read, write: if request.auth != null && (isDeveloper() || (request.auth.uid == resource.data.userId && isTenantMember(request.auth.token.companyId)));
    }

    // 🛡️ السماح للموظفين برؤية طلباتهم الخاصة بالاستئذان والإجازات حتى لو فشل الكليم المباشر في بعض المتصفحات
    match /{path=**}/leaveRequests/{id} {
        allow read: if request.auth != null && (isDeveloper() || resource.data.employeeId == request.auth.token.employeeId || resource.data.createdBy == request.auth.uid);
    }
    match /{path=**}/permissionRequests/{id} {
        allow read: if request.auth != null && (isDeveloper() || resource.data.employeeId == request.auth.token.employeeId || resource.data.createdBy == request.auth.uid);
    }
  }
}
