rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isAuthOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      // Default to 'Client' role if user document doesn't exist or has no role
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    function isSecretary() {
        return getUserRole() == 'secretary';
    }

    function isHR() {
        return getUserRole() == 'hr';
    }

    match /users/{userId} {
      // Admins can read any user profile.
      // Any authenticated user can read their own profile. This is crucial for role checks.
      allow read: if isAdmin() || (isAuthenticated() && isAuthOwner(userId));
      // Only Admins can create or update user profiles.
      allow write: if isAdmin();
    }
    
    match /clients/{clientId} {
      allow read, write: if isAdmin() || isSecretary();
    }

    match /employees/{employeeId} {
      allow read: if isAdmin() || isHR() || isSecretary();
      allow create: if isAdmin() || isHR() || isSecretary();
      allow update, delete: if isAdmin() || isHR();
    }
  }
}
