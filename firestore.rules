rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 🛡️ بروتوكول المعماري السيادي (V41.0) ---
    // هذا الاستثناء يسمح لبريدك الشخصي alaawaaheeb@gmail.com بتجاوز كافة الحواجز
    function isDeveloper() {
      return request.auth != null && 
             (request.auth.token.role == 'Developer' || 
              request.auth.token.email.lower() == 'alaawaaheeb@gmail.com');
    }

    function belongsToCompany(companyId) {
      return request.auth != null && 
             (request.auth.token.companyId == companyId || request.auth.token.currentCompanyId == companyId);
    }

    // --- 1. المنشآت والبيانات المعزولة ---
    match /companies/{companyId} {
      allow read, write: if isDeveloper() || belongsToCompany(companyId);
      
      match /{allSubcollections=**} {
        allow read, write: if isDeveloper() || belongsToCompany(companyId);
      }
    }

    // --- 2. الفهارس والطلبات (مفتوحة للمطور للتحكم) ---
    match /global_users/{docId} {
      allow read, write: if isDeveloper();
    }
    
    match /company_requests/{requestId} {
      allow create: if true;
      allow read, write: if isDeveloper();
    }

    match /developers/{uid} {
      allow read, write: if isDeveloper() || (request.auth != null && request.auth.token.email.lower() == 'alaawaaheeb@gmail.com');
    }

    // --- 3. الحماية الافتراضية الشاملة ---
    match /{document=**} {
      allow read, write: if isDeveloper();
    }
  }
}
