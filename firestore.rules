
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'Admin';
    }
    
    function isHR() {
      return isAuthenticated() && getUserData().role == 'HR';
    }

    // --- Path Rules ---

    match /users/{userId} {
      // Admins can read/write all user profiles.
      // Users can only read/update their own profile.
      allow read, write: if isAdmin();
      allow read, update: if isAuthenticated() && request.auth.uid == userId;
    }

    match /employees/{employeeId} {
      // Admins and HR can manage all employee records.
      // Employees can read their own record.
      allow read, write: if isAdmin() || isHR();
      allow read: if isAuthenticated() && getUserData().employeeId == employeeId;
    }

    match /clients/{clientId} {
      // Admins and Secretaries can manage clients.
      // Engineers can read client data.
      allow read, write: if isAdmin() || (isAuthenticated() && getUserData().role == 'Secretary');
      allow read: if isAuthenticated() && getUserData().role == 'Engineer';
    }

    // Default deny all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
