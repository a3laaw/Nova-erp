
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ مصفوفة الصلاحيات الموحدة (V140.0 - Dynamic Profession Edition) 🛡️
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDeveloper() {
      return isAuthenticated() && 
             (request.auth.token.role == 'Developer' || 
              request.auth.token.email.lower() == 'alaawaaheeb@gmail.com');
    }

    function isTenantMember(companyId) {
      return isAuthenticated() && 
             (request.auth.token.companyId == companyId || 
              request.auth.token.currentCompanyId == companyId);
    }

    // رادار فحص الصلاحيات من المصفوفة الديناميكية
    function hasPermission(companyId, module, action) {
        let role = request.auth.token.role;
        let matrix = get(/databases/$(database)/documents/companies/$(companyId)/settings/permissions_matrix).data.data;
        let key = role + "-" + module + "-" + action;
        return matrix[key] == true;
    }

    // هل يملك صلاحية إدارية عليا؟
    function isAdminPower() {
        return request.auth.token.role == 'Admin' || isDeveloper();
    }

    match /{document=**} {
      allow read, write: if isDeveloper();
    }

    match /companies/{companyId} {
      allow read: if isDeveloper() || isTenantMember(companyId);
      allow write: if isDeveloper() || isTenantMember(companyId);
      
      // 🏢 إدارة العملاء (CRM) 🏢
      match /clients/{clientId} {
        allow read: if isTenantMember(companyId) && (hasPermission(companyId, 'clients', 'view') || isAdminPower());
        allow create: if isTenantMember(companyId) && (hasPermission(companyId, 'clients', 'create') || isAdminPower());
        allow update: if isTenantMember(companyId) && (hasPermission(companyId, 'clients', 'update') || isAdminPower());
        allow delete: if isTenantMember(companyId) && (hasPermission(companyId, 'clients', 'delete') || isAdminPower());
      }

      // 📂 المعاملات والمسار الفني 📂
      match /transactions/{txId} {
        allow read: if isTenantMember(companyId) && (hasPermission(companyId, 'transactions', 'view') || isAdminPower());
        allow create, update: if isTenantMember(companyId) && (hasPermission(companyId, 'transactions', 'create') || isAdminPower());
        allow delete: if isAdminPower();
      }

      // 🏗️ الزيارات الميدانية 🏗️
      match /field_visits/{visitId} {
        allow read: if isTenantMember(companyId) && (hasPermission(companyId, 'site_visits', 'view') || isAdminPower());
        allow create, update: if isTenantMember(companyId) && (hasPermission(companyId, 'site_visits', 'create') || isAdminPower());
        allow delete: if isAdminPower();
      }

      // 💰 المحاسبة والمالية 💰
      match /journalEntries/{id} {
        allow read, write: if isTenantMember(companyId) && (hasPermission(companyId, 'journal_entries', 'view') || isAdminPower());
      }
      
      match /cashReceipts/{id} {
        allow read, write: if isTenantMember(companyId) && (hasPermission(companyId, 'vouchers', 'view') || isAdminPower());
      }

      // 👥 الموارد البشرية 👥
      match /employees/{id} {
        allow read: if isTenantMember(companyId) && (hasPermission(companyId, 'hr_employees', 'view') || isAdminPower());
        allow write: if isTenantMember(companyId) && (hasPermission(companyId, 'hr_employees', 'create') || isAdminPower());
      }

      // ⚙️ الإعدادات (Sovereign Settings) ⚙️
      match /settings/{id} {
        allow read: if isTenantMember(companyId);
        allow write: if isAdminPower();
      }
      
      match /{allSubcollections=**} {
        allow read, write: if isDeveloper() || isTenantMember(companyId);
      }
    }

    match /global_users/{uid} {
      allow read: if true; 
      allow write: if isDeveloper() || (isAuthenticated() && request.auth.uid == uid);
    }
  }
}
