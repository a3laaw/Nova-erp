rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // This function now securely reads the role from the auth token claims
    function getUserRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'Admin';
    }

    function isSecretary() {
      return isAuthenticated() && getUserRole() == 'Secretary';
    }

    function isHR() {
      return isAuthenticated() && getUserRole() == 'HR';
    }
    
    function isEngineer() {
      return isAuthenticated() && getUserRole() == 'Engineer';
    }
    
    // Checks if the requesting user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Path Rules
    match /users/{userId} {
      // Allow an unauthenticated user to query for their username during login.
      // NOTE: This is a temporary, less-secure rule for development.
      // In production, this check should be handled by a server-side function.
      allow list: if true;

      // An authenticated user can get their OWN profile. Admins can get any user.
      allow get: if isOwner(userId) || isAdmin();

      // Only Admins or the user themselves can update a profile.
      allow update: if isOwner(userId) || isAdmin();
      
      // Allow user creation for sign-up flows (if any).
      allow create: if true;
    }
    
    match /clients/{clientId} {
      // Admins and Secretaries can manage clients.
      allow read, write: if isAdmin() || isSecretary();
    }

    match /employees/{employeeId} {
      // Admins and HR can manage employees. Secretaries can read/create.
      allow read, create: if isAdmin() || isHR() || isSecretary();
      allow update, delete: if isAdmin() || isHR();
    }
    
    // Default deny all other reads/writes for security.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
