
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Returns true if the user has the 'Admin' role in their custom claims.
    function isAdmin() {
        return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Path Rules
    match /users/{userId} {
      // Admins can manage all users.
      // Users can read/update their own profile.
      allow read, update: if isOwner(userId) || isAdmin();
      allow list, create, delete: if isAdmin();
    }
    
    match /clients/{clientId} {
      allow read, write: if isAuthenticated();
    }

    match /employees/{employeeId} {
      // Allow admins and HR to manage employees.
      // Allow any authenticated user to read for now.
      allow read: if isAuthenticated();
      allow write: if isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'HR';
    }
  }
}
