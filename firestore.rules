
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ مصفوفة الصلاحيات السيادية (V145.0 - Dynamic Integration Edition) 🛡️
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDeveloper() {
      return isAuthenticated() && 
             (request.auth.token.role == 'Developer' || 
              request.auth.token.email.lower() == 'alaawaaheeb@gmail.com');
    }

    function isTenantMember(companyId) {
      return isAuthenticated() && 
             (request.auth.token.companyId == companyId || 
              request.auth.token.currentCompanyId == companyId);
    }

    // رادار فحص الصلاحيات من مصفوفة المهن الديناميكية
    function checkPerm(companyId, module, level) {
        let role = request.auth.token.role;
        let matrix = get(/databases/$(database)/documents/companies/$(companyId)/settings/permissions_matrix).data.data;
        let val = matrix[role + "-" + module];
        
        // كامل = full
        // جزئي = partial (يحتاج معالجة إضافية في الفلترة)
        // عرض = view
        // مخفي = none
        
        return (level == 'view' && (val == 'view' || val == 'partial' || val == 'full')) ||
               (level == 'write' && (val == 'partial' || val == 'full')) ||
               (level == 'admin' && val == 'full');
    }

    // هل يملك صلاحية إدارية عليا؟
    function isAdminPower() {
        return request.auth.token.role == 'Admin' || isDeveloper();
    }

    match /{document=**} {
      allow read, write: if isDeveloper();
    }

    // Allow reading the 'transactions' collection group for tenant members
    match /{path=**}/transactions/{txId} {
      allow read: if isAuthenticated() && 
                      (request.auth.token.companyId == resource.data.companyId ||
                       request.auth.token.currentCompanyId == resource.data.companyId);
    }

    match /companies/{companyId} {
      allow read: if isDeveloper() || isTenantMember(companyId);
      allow write: if isDeveloper();
      
      // 🏢 إدارة العملاء 🏢
      match /clients/{clientId} {
        allow read: if isTenantMember(companyId) && (checkPerm(companyId, 'clients', 'view') || isAdminPower());
        allow create, update: if isTenantMember(companyId) && (checkPerm(companyId, 'clients', 'write') || isAdminPower());
        allow delete: if isAdminPower();
      }

      // 📂 المعاملات والمسار الفني (For direct access, not collection group)
      match /transactions/{txId} {
        allow read: if isTenantMember(companyId) && (checkPerm(companyId, 'transactions', 'view') || isAdminPower());
        allow create, update: if isTenantMember(companyId) && (checkPerm(companyId, 'transactions', 'write') || isAdminPower());
        allow delete: if isAdminPower();
      }

      // 🏗️ الزيارات الميدانية 🏗️
      match /field_visits/{visitId} {
        allow read: if isTenantMember(companyId) && (checkPerm(companyId, 'site_visits', 'view') || isAdminPower());
        allow create, update: if isTenantMember(companyId) && (checkPerm(companyId, 'site_visits', 'write') || isAdminPower());
        allow delete: if isAdminPower();
      }

      // 💰 المحاسبة والمالية 💰
      match /chartOfAccounts/{accountId} {
        allow read: if isTenantMember(companyId) && (checkPerm(companyId, 'journal_entries', 'view') || isAdminPower());
        allow write: if isAdminPower();
      }

      match /journalEntries/{id} {
        allow read: if isTenantMember(companyId) && (checkPerm(companyId, 'journal_entries', 'view') || isAdminPower());
        allow create, update: if isTenantMember(companyId) && (checkPerm(companyId, 'journal_entries', 'write') || isAdminPower());
      }
      
      match /cashReceipts/{id} {
        allow read: if isTenantMember(companyId) && (checkPerm(companyId, 'vouchers', 'view') || isAdminPower());
        allow create: if isTenantMember(companyId) && (checkPerm(companyId, 'vouchers', 'write') || isAdminPower());
      }

      // 👥 الموارد البشرية 👥
      match /employees/{id} {
        allow read: if isTenantMember(companyId) && (checkPerm(companyId, 'hr_employees', 'view') || isAdminPower());
        allow write: if isTenantMember(companyId) && (checkPerm(companyId, 'hr_employees', 'write') || isAdminPower());
      }

      // ⚙️ الإعدادات السيادية ⚙️
      match /settings/{id} {
        allow read: if isTenantMember(companyId);
        allow write: if isAdminPower();
      }
      
      match /{allSubcollections=**} {
        allow read, write: if isDeveloper() || isTenantMember(companyId);
      }
    }

    match /global_users/{uid} {
      allow read: if true; 
      allow write: if isDeveloper() || (isAuthenticated() && request.auth.uid == uid);
    }
  }
}
