
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'Admin';
    }
    
    function isHR() {
      return isAuthenticated() && getUserData().role == 'HR';
    }

    // --- Path Rules ---

    // Login: Any authenticated user (including anonymous) needs to be able to query the users collection
    // to find their own document by username. This is a limited, secure read.
    match /users/{userId} {
      // Admins can manage all users.
      allow read, write: if isAdmin();
      
      // Allow any authenticated user to read their own profile after login.
      allow get: if isAuthenticated() && request.auth.uid == userId;
    }
    
    match /clients/{clientId} {
      allow read, write: if isAuthenticated();
    }

    match /employees/{employeeId} {
      // Admins and HR can manage employees.
      // Any authenticated user can read the list for now (e.g., for forms).
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isHR();
    }
  }
}
