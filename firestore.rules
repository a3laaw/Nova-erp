rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ مصفوفة الصلاحيات الموحدة (V130.0 - Sovereign Master Edition)
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // ⚡ محرك التعرف على المطور السيادي (Sovereign ID Engine)
    // يدعم الرتبة (Role) أو البريد المباشر كدرع حماية احتياطي للمطور الرئيسي
    function isDeveloper() {
      return isAuthenticated() && 
             (request.auth.token.role == 'Developer' || 
              request.auth.token.isSuperAdmin == true ||
              request.auth.token.email.lower() == 'alaawaaheeb@gmail.com');
    }

    function isTenantMember(companyId) {
      return isAuthenticated() && 
             (request.auth.token.companyId == companyId || 
              request.auth.token.currentCompanyId == companyId);
    }

    // 🏯 قاعدة الوصول الشاملة للمطور المعتمد (Master Key)
    match /{document=**} {
      allow read, write: if isDeveloper();
    }

    // 🌍 محركات النظام العالمية (Sovereign Global Collections)
    // مفتوحة للقراءة للجميع (لجلب القاموس) ومقفلة للكتابة إلا للمطور
    match /system_lexicon/{id} {
      allow read: if isAuthenticated();
      allow write: if isDeveloper();
    }
    
    match /framework_config/{id} {
      allow read: if isAuthenticated();
      allow write: if isDeveloper();
    }

    // 🏢 عزل بيانات المنشآت (Multi-tenancy Isolation)
    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow write: if isDeveloper() || isTenantMember(companyId);
      
      match /{allSubcollections=**} {
        allow read, write: if isDeveloper() || isTenantMember(companyId);
      }
    }

    // 🌍 الفهرس العالمي للمستخدمين
    match /global_users/{uid} {
      allow read: if true; 
      allow write: if isDeveloper() || (isAuthenticated() && request.auth.uid == uid);
    }
    
    match /company_requests/{id} {
      allow create: if isAuthenticated(); 
      allow read, write: if isDeveloper();
    }
  }
}