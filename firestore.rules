rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 🛡️ بروتوكول المعماري السيادي (V44.0) ---
    // السلطة المطلقة لبريدك الشخصي لكسر أي حلقة مفرغة
    function isSovereignArchitect() {
      return request.auth != null && 
             (request.auth.token.role == 'Developer' || 
              request.auth.token.email.lower() == 'alaawaaheeb@gmail.com');
    }

    function belongsToCompany(companyId) {
      return request.auth != null && 
             (request.auth.token.companyId == companyId || request.auth.token.currentCompanyId == companyId);
    }

    // السماح لبريدك بالكتابة في مجموعة المطورين لتأسيس الجلسة الأولى
    match /developers/{uid} {
      allow read, write: if isSovereignArchitect() || (request.auth != null && request.auth.token.email.lower() == 'alaawaaheeb@gmail.com');
    }

    match /companies/{companyId} {
      allow read, write: if isSovereignArchitect() || belongsToCompany(companyId);
      
      match /{allSubcollections=**} {
        allow read, write: if isSovereignArchitect() || belongsToCompany(companyId);
      }
    }

    match /global_users/{docId} {
      allow read, write: if isSovereignArchitect();
    }
    
    match /company_requests/{requestId} {
      allow create: if true;
      allow read, write: if isSovereignArchitect();
    }

    match /{document=**} {
      allow read, write: if isSovereignArchitect();
    }
  }
}
