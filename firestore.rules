
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // WARNING: These rules are temporarily open for development purposes.
    // They allow anyone to read and write to the database.
    // TODO: Re-implement proper security rules before deploying to production.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
