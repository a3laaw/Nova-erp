rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      // In a real app with custom claims, this would be: request.auth.token.role
      // As a fallback, we read from the user's public profile document.
      // This requires that users can read their own profile.
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      if (exists(/databases/$(database)/documents/users/$(request.auth.uid))) {
        return userDoc.data.role;
      }
      return 'Client'; // Default role if profile doesn't exist
    }

    function isAdmin() {
      return getUserRole() == 'Admin';
    }

    function isSecretary() {
        return getUserRole() == 'Secretary';
    }

    function isHR() {
        return getUserRole() == 'HR';
    }
    
    function isEngineer() {
        return getUserRole() == 'Engineer';
    }

    // Path Rules
    match /users/{userId} {
      // Any authenticated user can read ANY user profile. This is required for getUserRole() to work.
      // In a more secure setup, you'd restrict this or use custom claims.
      allow read: if isAuthenticated();
      
      // Only Admins can create or update user profiles.
      allow write: if isAdmin();
    }
    
    match /clients/{clientId} {
      // Admins and Secretaries can manage clients.
      allow read, write: if isAdmin() || isSecretary();
    }

    match /employees/{employeeId} {
      // Admins, HR, and Secretaries can read and create employees.
      allow read, create: if isAdmin() || isHR() || isSecretary();
      // Only Admins and HR can update or delete employees.
      allow update, delete: if isAdmin() || isHR();
    }
    
    // Default deny all other reads/writes
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
